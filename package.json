{
  "name": "polynomial-fan-matcher",
  "version": "0.1.0",
  "description": "Select optimal HVAC fan for a given duty point from polynomial P-Q curves. Extracted from VENTMARKET.",
  "keywords": [
    "hvac",
    "ventilation",
    "fan-selection",
    "polynomial",
    "engineering",
    "cfd",
    "mep",
    "building-services"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goncharovart/polynomial-fan-matcher.git"
  },
  "license": "MIT",
  "author": "Artur Goncharov <goncharov.artur.02@gmail.com>",
  "homepage": "https://github.com/goncharovart/polynomial-fan-matcher#readme",
  "bugs": {
    "url": "https://github.com/goncharovart/polynomial-fan-matcher/issues"
  }
}
